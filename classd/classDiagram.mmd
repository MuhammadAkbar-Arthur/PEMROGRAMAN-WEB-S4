classDiagram
    namespace Framework {
        class Controller {
            <<framework>>
        }
    }

    namespace Controllers {
        class BaseController {
            <<abstract>>
            #checkLogin()
        }

        class Auth {
            +login()
            +processLogin()
            +register()
            +processRegister()
            +logout()
            +forgotPassword()
            +forgotPasswordProcess()
            +resetPassword()
            +resetPasswordProcess()
            -redirectBasedOnRole(role: string) Response
        }

        class Home {
            +index()
        }

        class Event {
            -request
            -db
            +index()
            +create()
            +store()
            +edit(id: int)
            +update(id: int)
            +delete(id: int)
            -getRedirectUrl() string
        }

        class Comment {
            +store(event_id: int)
            +delete(id: int)
        }

        class Booking {
            +create(event_id: int)
            +myBookings()
            +delete(id: int)
            +approve(id: int)
            +reject(id: int)
            +ticket(booking_id: int)
            -sendBookingEmail(id: int)
        }

        class Favorite {
            +add(event_id: int)
            +remove(event_id: int)
            +index()
        }

        class Profile {
            +index()
            +update()
        }

        class Category {
            +index()
            +store()
            +delete(id: int)
            +update(id: int)
        }

        class Admin {
            -db
            +index()
            +deleteEvent(id: int)
        }

        class Organizer {
            -db
            -userId
            +index()
            +bookings()
            +myEvents()
        }
    }

    namespace Models {
        class Model {
            <<framework>>
        }

        class UserModel {
            #table: string
            #allowedFields: array
            -id: int
            -name: string
            -email: string
            -password: string
            -role: string
            -avatar: string
            -bio: string
            -phone: string
        }

        class EventModel {
            #table: string
            #allowedFields: array
            -id: int
            -owner_id: int
            -title: string
            -description: string
            -date: date
            -location: string
            -category_id: int
            -image: string
            -quota: int
            -price: decimal
        }

        class CommentModel {
            #table: string
            #allowedFields: array
            -id: int
            -user_id: int
            -event_id: int
            -comment: text
            -created_at: datetime
        }

        class BookingModel {
            #table: string
            #allowedFields: array
            -id: int
            -user_id: int
            -event_id: int
            -status: string
            -created_at: datetime
            -updated_at: datetime
        }

        class FavoriteModel {
            #table: string
            #allowedFields: array
            -id: int
            -user_id: int
            -event_id: int
            -created_at: datetime
        }

        class CategoryModel {
            #table: string
            #allowedFields: array
            -id: int
            -name: string
            -created_at: datetime
        }
    }

    namespace Views {
        class View {
            <<view>>
            -$data: array
        }

        class LoginView {
            -$data: array
            -$error: string
            -$email: string
        }

        class RegisterView {
            -$data: array
            -$errors: array
        }

        class EventIndexView {
            -$events: array
            -$role: string
            -$logged_in: boolean
        }

        class EventDetailView {
            -$event: array
            -$comments: array
            -$currentUserId: int
            -$isBooked: boolean
            -$isFavorite: boolean
        }

        class BookingView {
            -$bookings: array
            -$userId: int
        }

        class FavoriteView {
            -$favorites: array
            -$userId: int
        }

        class ProfileView {
            -$user: array
            -$userId: int
        }

        class AdminDashboardView {
            -$totalUsers: int
            -$totalEvents: int
            -$totalBookings: int
            -$bookings: array
            -$all_events: array
        }

        class OrganizerDashboardView {
            -$totalEvents: int
            -$totalBookings: int
            -$upcoming: array
        }
    }

    %% Framework inheritance
    Controller <|-- BaseController

    %% Controller inheritance
    BaseController <|-- Auth
    BaseController <|-- Home
    BaseController <|-- Event
    BaseController <|-- Comment
    BaseController <|-- Booking
    BaseController <|-- Favorite
    BaseController <|-- Profile
    BaseController <|-- Category
    BaseController <|-- Admin
    BaseController <|-- Organizer

    %% Model inheritance
    Model <|-- UserModel
    Model <|-- EventModel
    Model <|-- CommentModel
    Model <|-- BookingModel
    Model <|-- FavoriteModel
    Model <|-- CategoryModel

    %% View inheritance
    View <|-- LoginView
    View <|-- RegisterView
    View <|-- EventIndexView
    View <|-- EventDetailView
    View <|-- BookingView
    View <|-- FavoriteView
    View <|-- ProfileView
    View <|-- AdminDashboardView
    View <|-- OrganizerDashboardView

    %% Controller uses Model
    Auth --> UserModel : uses
    Event --> EventModel : uses
    Event --> CategoryModel : uses
    Comment --> CommentModel : uses
    Comment --> EventModel : uses
    Booking --> BookingModel : uses
    Booking --> EventModel : uses
    Booking --> UserModel : uses
    Favorite --> FavoriteModel : uses
    Favorite --> EventModel : uses
    Profile --> UserModel : uses
    Category --> CategoryModel : uses
    Admin --> UserModel : uses
    Admin --> EventModel : uses
    Admin --> BookingModel : uses
    Organizer --> EventModel : uses
    Organizer --> BookingModel : uses

    %% Controller renders View
    Auth --> LoginView
    Auth --> RegisterView
    Home --> EventIndexView
    Event --> EventIndexView
    Event --> EventDetailView
    Booking --> BookingView
    Favorite --> FavoriteView
    Profile --> ProfileView
    Category --> AdminDashboardView
    Admin --> AdminDashboardView
    Organizer --> OrganizerDashboardView

    %% Data relationships
    UserModel "1" -- "*" EventModel : owns
    UserModel "1" -- "*" BookingModel : creates
    EventModel "1" -- "*" BookingModel : has
    EventModel "1" -- "*" CommentModel : has
    EventModel "1" -- "*" FavoriteModel : has
    CategoryModel "1" -- "*" EventModel : categorizes

