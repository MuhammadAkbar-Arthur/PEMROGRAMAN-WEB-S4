flowchart TD
    Start([Mulai])
    OpenEventMenu[Admin/Organizer membuka menu event]
    AuthCheck{Role admin atau organizer?}
    Denied[Akses ditolak]
    ChooseAction{Pilih aksi}
    ListEvents[Tampilkan daftar event]
    CreateForm[Tampilkan form tambah event]
    ValidateCreate{Data dan gambar valid?}
    CreateError[Tampilkan error input]
    SaveEvent[Simpan event dengan owner login]
    EditForm[Tampilkan form edit event]
    OwnerCheck{Organizer pemilik event?}
    EditDenied[Akses edit ditolak]
    ValidateUpdate{Data update valid?}
    UpdateError[Tampilkan error input]
    UpdateEvent[Update data event dan gambar bila ada]
    DeleteCheck{Event ditemukan dan boleh dihapus?}
    DeleteDenied[Tampilkan error hapus]
    DeleteEvent[Hapus gambar dan data event]
    RedirectList[Kembali ke daftar event]
    End([Selesai])

    Start --> OpenEventMenu --> AuthCheck
    AuthCheck -- Tidak --> Denied --> End
    AuthCheck -- Ya --> ChooseAction
    ChooseAction -- Lihat --> ListEvents --> End
    ChooseAction -- Tambah --> CreateForm --> ValidateCreate
    ValidateCreate -- Tidak --> CreateError --> CreateForm
    ValidateCreate -- Ya --> SaveEvent --> RedirectList --> End
    ChooseAction -- Edit --> EditForm --> OwnerCheck
    OwnerCheck -- Tidak --> EditDenied --> End
    OwnerCheck -- Ya --> ValidateUpdate
    ValidateUpdate -- Tidak --> UpdateError --> EditForm
    ValidateUpdate -- Ya --> UpdateEvent --> RedirectList --> End
    ChooseAction -- Hapus --> DeleteCheck
    DeleteCheck -- Tidak --> DeleteDenied --> End
    DeleteCheck -- Ya --> DeleteEvent --> RedirectList --> End
