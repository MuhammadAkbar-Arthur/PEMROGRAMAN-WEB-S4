flowchart TD
    Start([Mulai])
    OpenCategory[Admin membuka menu kategori]
    RoleCheck{Role admin?}
    Denied[Akses ditolak]
    ShowCategories[Tampilkan daftar kategori]
    ChooseAction{Pilih aksi}

    AddInput[Isi nama kategori baru]
    AddNameValid{Nama kategori terisi?}
    AddDuplicate{Nama kategori sudah ada?}
    SaveCategory[Simpan kategori baru]

    EditSelect[Pilih kategori yang akan diedit]
    EditFound{Kategori ditemukan?}
    EditInput[Isi nama kategori baru]
    EditNameValid{Nama kategori terisi?}
    EditDuplicate{Nama dipakai kategori lain?}
    UpdateCategory[Update nama kategori]

    DeleteSelect[Pilih kategori yang akan dihapus]
    DeleteFound{Kategori ditemukan?}
    DeleteCategory[Hapus kategori]

    Error[Tampilkan pesan error]
    Back[Kembali ke daftar kategori]
    End([Selesai])

    Start --> OpenCategory --> RoleCheck
    RoleCheck -- Tidak --> Denied --> End
    RoleCheck -- Ya --> ShowCategories --> ChooseAction

    ChooseAction -- Tambah --> AddInput --> AddNameValid
    AddNameValid -- Tidak --> Error --> ShowCategories
    AddNameValid -- Ya --> AddDuplicate
    AddDuplicate -- Ya --> Error
    AddDuplicate -- Tidak --> SaveCategory --> Back --> End

    ChooseAction -- Edit --> EditSelect --> EditFound
    EditFound -- Tidak --> Error
    EditFound -- Ya --> EditInput --> EditNameValid
    EditNameValid -- Tidak --> Error
    EditNameValid -- Ya --> EditDuplicate
    EditDuplicate -- Ya --> Error
    EditDuplicate -- Tidak --> UpdateCategory --> Back

    ChooseAction -- Hapus --> DeleteSelect --> DeleteFound
    DeleteFound -- Tidak --> Error
    DeleteFound -- Ya --> DeleteCategory --> Back
