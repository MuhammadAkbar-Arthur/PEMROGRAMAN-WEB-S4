flowchart TD
    Start([Mulai])
    OpenRegister[Pengunjung membuka halaman register]
    AlreadyLogin{Sudah login?}
    RedirectRole[Arahkan ke halaman sesuai role]
    FillForm[Isi nama email password dan konfirmasi]
    Validate{Data valid?}
    ShowValidation[Tampilkan pesan validasi]
    UniqueEmail{Email belum digunakan?}
    DuplicateEmail[Tampilkan pesan email sudah digunakan]
    HashPassword[Hash password]
    SaveUser[Simpan akun baru dengan role user]
    RedirectLogin[Arahkan ke halaman login]
    End([Selesai])

    Start --> OpenRegister --> AlreadyLogin
    AlreadyLogin -- Ya --> RedirectRole --> End
    AlreadyLogin -- Tidak --> FillForm --> Validate
    Validate -- Tidak --> ShowValidation --> FillForm
    Validate -- Ya --> UniqueEmail
    UniqueEmail -- Tidak --> DuplicateEmail --> FillForm
    UniqueEmail -- Ya --> HashPassword --> SaveUser --> RedirectLogin --> End
