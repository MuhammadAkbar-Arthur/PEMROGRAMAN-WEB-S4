flowchart TD
    Start([Mulai])
    OpenDetail[User membuka detail event]
    SubmitComment[User mengirim komentar]
    LoginCheck{Sudah login?}
    RedirectLogin[Arahkan ke halaman login]
    TrimComment[Sistem membersihkan input komentar]
    EmptyCheck{Komentar kosong?}
    EmptyError[Tampilkan pesan komentar tidak boleh kosong]
    SaveComment[Simpan komentar dengan user_id dan event_id]
    BackDetail[Kembali ke detail event]
    End([Selesai])

    Start --> OpenDetail --> SubmitComment --> LoginCheck
    LoginCheck -- Tidak --> RedirectLogin --> End
    LoginCheck -- Ya --> TrimComment --> EmptyCheck
    EmptyCheck -- Ya --> EmptyError --> BackDetail
    EmptyCheck -- Tidak --> SaveComment --> BackDetail --> End
