flowchart TD
    Start([Mulai])
    OpenHome[Pengunjung membuka halaman utama]
    LoadCategories[Sistem mengambil daftar kategori]
    InputFilter{Mengisi filter pencarian?}
    ApplyFilter[Masukkan keyword lokasi kategori atau sort]
    QueryEvents[Sistem mengambil event dan join kategori]
    ShowEvents[Tampilkan daftar event]
    SelectEvent[Pilih salah satu event]
    LoadDetail[Sistem mengambil detail event, kategori, dan organizer]
    EventFound{Event ditemukan?}
    NotFound[Tampilkan pesan event tidak ditemukan]
    CountQuota[Hitung booking approved dan sisa kuota]
    CheckUserState{User sedang login?}
    CheckBookingFavorite[Cek status booking dan wishlist user]
    LoadComments[Ambil komentar event]
    ShowDetail[Tampilkan halaman detail event]
    End([Selesai])

    Start --> OpenHome --> LoadCategories --> InputFilter
    InputFilter -- Ya --> ApplyFilter --> QueryEvents
    InputFilter -- Tidak --> QueryEvents
    QueryEvents --> ShowEvents --> SelectEvent --> LoadDetail --> EventFound
    EventFound -- Tidak --> NotFound --> End
    EventFound -- Ya --> CountQuota --> CheckUserState
    CheckUserState -- Ya --> CheckBookingFavorite --> LoadComments
    CheckUserState -- Tidak --> LoadComments
    LoadComments --> ShowDetail --> End
