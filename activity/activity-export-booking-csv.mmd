flowchart TD
    Start([Mulai])
    ClickExport[Admin klik export CSV]
    RoleCheck{Role admin?}
    Denied[Akses ditolak]
    QueryData[Ambil data booking join users dan events]
    SetHeader[Set header response text/csv dan nama file]
    WriteColumn[Tulis kolom User Event Date Location Status]
    HasRows{Masih ada data booking?}
    WriteRow[Tulis baris data booking ke CSV]
    CloseFile[Tutup output CSV]
    Download[Browser mengunduh booking_data.csv]
    End([Selesai])

    Start --> ClickExport --> RoleCheck
    RoleCheck -- Tidak --> Denied --> End
    RoleCheck -- Ya --> QueryData --> SetHeader --> WriteColumn --> HasRows
    HasRows -- Ya --> WriteRow --> HasRows
    HasRows -- Tidak --> CloseFile --> Download --> End
