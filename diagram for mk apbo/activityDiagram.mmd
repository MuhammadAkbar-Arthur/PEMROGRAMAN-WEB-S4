flowchart TD
    Start([Mulai])
    OpenHome[User membuka halaman utama]
    Browse[Melihat daftar event]
    Search{Cari/filter event?}
    ApplyFilter[Masukkan keyword lokasi kategori atau sort]
    ShowResults[Sistem menampilkan hasil event]
    SelectEvent[Pilih event]
    Detail[Sistem menampilkan detail event, kuota, wishlist, booking, komentar]
    LoggedIn{Sudah login?}
    Login[Login atau register]
    RoleCheck{Role user biasa?}
    Denied[Booking ditolak karena admin/organizer tidak boleh booking]
    QuotaCheck{Kuota approved masih tersedia?}
    Full[Event penuh]
    DuplicateCheck{Sudah pernah booking?}
    Duplicate[Tampilkan pesan sudah booking]
    SaveBooking[Simpan booking status pending]
    Notify[Siapkan notifikasi status booking]
    Waiting[User menunggu approval]
    OrganizerReview[Organizer/Admin melihat daftar booking]
    Decision{Booking disetujui?}
    Approve[Update status approved]
    Reject[Update status rejected]
    UserCheck[User membuka My Bookings]
    ApprovedCheck{Status approved?}
    DownloadTicket[Download tiket PDF berisi QR]
    VerifyQR[Scan/verifikasi QR tiket]
    End([Selesai])

    Start --> OpenHome --> Browse --> Search
    Search -- Ya --> ApplyFilter --> ShowResults
    Search -- Tidak --> ShowResults
    ShowResults --> SelectEvent --> Detail --> LoggedIn
    LoggedIn -- Tidak --> Login --> Detail
    LoggedIn -- Ya --> RoleCheck
    RoleCheck -- Bukan user --> Denied --> End
    RoleCheck -- User --> QuotaCheck
    QuotaCheck -- Tidak --> Full --> End
    QuotaCheck -- Ya --> DuplicateCheck
    DuplicateCheck -- Ya --> Duplicate --> End
    DuplicateCheck -- Tidak --> SaveBooking --> Notify --> Waiting
    Waiting --> OrganizerReview --> Decision
    Decision -- Ya --> Approve --> UserCheck
    Decision -- Tidak --> Reject --> UserCheck
    UserCheck --> ApprovedCheck
    ApprovedCheck -- Ya --> DownloadTicket --> VerifyQR --> End
    ApprovedCheck -- Tidak --> End
